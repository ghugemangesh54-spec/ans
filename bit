Bit Stuffing
#include <stdio.h>

int main() {
    int data[50], stuffed[100];
    int i, j = 0, count = 0, n;

    printf("Enter number of bits: ");
    scanf("%d", &n);

    printf("Enter bits: ");
    for(i = 0; i < n; i++)
        scanf("%d", &data[i]);

    for(i = 0; i < n; i++) {
        stuffed[j] = data[i];

        if(data[i] == 1)
            count++;
        else
            count = 0;

        if(count == 5) {
            stuffed[++j] = 0;
            count = 0;
        }
        j++;
    }

    printf("Stuffed Data: ");
    for(i = 0; i < j; i++)
        printf("%d", stuffed[i]);

    return 0;
}
