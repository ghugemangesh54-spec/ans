#include <stdio.h>
#include <string.h>

int main() {
    char data[100];
    int i, len;

    printf("Enter data string: ");
    scanf("%s", data);

    len = strlen(data);

    printf("\nFramed Data (Character Count Method):\n");

    // Add count at beginning
    printf("%d", len);

    // Print actual data
    for(i = 0; i < len; i++) {
        printf("%c", data[i]);
    }

    printf("\n");

    return 0;
}
